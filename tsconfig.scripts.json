{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["node", "vite/client"]
  },
  "include": ["scripts/**/*.ts", "src/services/worldcup/**/*.ts", "src/entities/**/*.ts"]
}
